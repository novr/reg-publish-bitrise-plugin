{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "incremental": true,
    "declaration": true,
    "target": "es2015",
    "module": "node16",
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "node16",
    "sourceMap": true,
    "stripInternal": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "plugins": [
      {
        "name": "typescript-eslint-language-service"
      }
    ]
  },
  "exclude": ["lib"]
}
